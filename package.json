{
  "name": "hackathon-team-tools",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "css": "tailwindcss -i ./src/styles.css -o ./public/styles.css --minify",
    "css:watch": "tailwindcss -i ./src/styles.css -o ./public/styles.css --watch",
    "build": "pnpm run css",
    "dev": "pnpm run css && wrangler dev",
    "deploy": "pnpm run css && wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:apply:local": "wrangler d1 execute hackathon --local --file=./migrations/0001_init.sql",
    "db:seed:local": "wrangler d1 execute hackathon --local --file=./seed.sql",
    "db:reset:local": "wrangler d1 execute hackathon --local --command=\"PRAGMA writable_schema=1; DELETE FROM sqlite_master; PRAGMA writable_schema=0; VACUUM;\" && pnpm run db:apply:local",
    "db:apply:remote": "wrangler d1 execute hackathon --remote --file=./migrations/0001_init.sql",
    "db:seed:remote": "wrangler d1 execute hackathon --remote --file=./seed.sql"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "wrangler": "^4.105.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "workerd"]
  }
}
